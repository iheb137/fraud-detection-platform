{
  "buildCommand": "cp src/environments/environment.docker.ts src/environments/environment.ts && npx ng build --configuration production",
  "outputDirectory": "dist/frontend/browser",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://fraud-backend-9w8t.onrender.com/api/:path*" },
    { "source": "/ml/:path*", "destination": "https://fraud-detection-platform-gu8h.onrender.com/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}